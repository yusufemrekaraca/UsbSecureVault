<Window x:Class="UsbSecureVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="USB Secure Vault" Height="620" Width="980" MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen" Background="#f5f6f8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1f2937" Padding="18,14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="EmergencyInfoButton" Content="Emergency Info" Margin="0,0,10,0" Padding="12,7" Click="EmergencyInfoButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="DeleteVaultButton" Content="Tüm Kasayı Sil" Margin="0,0,10,0" Padding="12,7" Click="DeleteVaultButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="TrustButton" Content="Bu bilgisayara güven" Margin="0,0,10,0" Padding="12,7" Click="TrustButton_Click"/>
                    <Button Content="Çıkış" Padding="12,7" Click="LogoutButton_Click"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="USB Secure Vault" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="StatusText" Text="Hazır" Foreground="#cbd5e1" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="EmergencyInfoBanner" Grid.Row="1" Background="#dc2626" Padding="18,12" Visibility="Collapsed">
            <DockPanel>
                <TextBlock Text="EMERGENCY INFO" Foreground="White" FontWeight="Bold" Margin="0,0,14,0" DockPanel.Dock="Left"/>
                <TextBlock x:Name="EmergencyInfoText" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="18">
            <Border x:Name="SetupPanel" Background="White" CornerRadius="6" Padding="26" Visibility="Collapsed">
                <StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="İlk Kurulum" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <TextBlock Text="Master şifre" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="SetupPasswordBox" Padding="8" Margin="0,0,0,12"/>
                    <TextBlock Text="Master şifre tekrar" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="SetupPasswordConfirmBox" Padding="8" Margin="0,0,0,12"/>
                    <TextBlock Text="Hatırlatma" Margin="0,0,0,5"/>
                    <TextBox x:Name="SetupHintBox" Padding="8" Margin="0,0,0,12"/>
                    <TextBlock Text="Emergency info" Margin="0,0,0,5"/>
                    <TextBox x:Name="SetupEmergencyInfoBox" Padding="8" Margin="0,0,0,18" MinHeight="74" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    <Button Content="Kasayı Oluştur" Padding="12,9" Click="SetupButton_Click"/>
                </StackPanel>
            </Border>

            <Border x:Name="MasterLoginPanel" Background="White" CornerRadius="6" Padding="26" Visibility="Collapsed">
                <StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Master Giriş" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>
                    <TextBlock x:Name="MasterHintText" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <TextBlock Text="Master şifre" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="MasterPasswordBox" Padding="8" Margin="0,0,0,18"/>
                    <Button Content="Giriş Yap" Padding="12,9" Click="MasterLoginButton_Click"/>
                </StackPanel>
            </Border>

            <Grid x:Name="VaultPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,14,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                            <Button Content="Yeni Alan Oluştur" Padding="10,8" Click="CreateUserButton_Click"/>
                            <Button x:Name="DeleteUserButton" Content="Alanı Sil" Padding="10,8" Margin="0,8,0,0" Click="DeleteUserButton_Click" IsEnabled="False"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Alanlar" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ListBox x:Name="UsersList" DisplayMemberPath="Name" SelectionChanged="UsersList_SelectionChanged"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" x:Name="AddFileButton" Content="Dosya Ekle" Padding="12,8" Margin="8,0,0,0" Click="AddFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="AddFolderButton" Content="Klasör Ekle" Padding="12,8" Margin="8,0,0,0" Click="AddFolderButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="RestoreFileButton" Content="Eski Yerine Çıkar" Padding="12,8" Margin="8,0,0,0" Click="RestoreFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="DeleteFileButton" Content="Sil" Padding="12,8" Margin="8,0,0,0" Click="DeleteFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="LockUserButton" Content="Alanı Kilitle" Padding="12,8" Click="LockUserButton_Click" IsEnabled="False"/>
                            <StackPanel>
                                <TextBlock x:Name="SelectedUserTitle" Text="Alan seçin" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedUserSubtitle" Text="Dosyalar yalnızca alan şifresi girilince görünür." Foreground="#64748b"/>
                            </StackPanel>
                        </DockPanel>

                        <ListView Grid.Row="1" x:Name="FilesList" MouseDoubleClick="FilesList_MouseDoubleClick" SelectionChanged="FilesList_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Dosya" DisplayMemberBinding="{Binding Name}" Width="360"/>
                                    <GridViewColumn Header="Boyut" DisplayMemberBinding="{Binding SizeText}" Width="110"/>
                                    <GridViewColumn Header="Eklenme" DisplayMemberBinding="{Binding AddedText}" Width="170"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
