<Window x:Class="UsbSecureVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="USB Secure Vault" Height="620" Width="1040" MinHeight="580" MinWidth="920"
        WindowStartupLocation="CenterScreen" Background="#09090B">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#09090B"/>
        <SolidColorBrush x:Key="TopBarBrush" Color="#111113"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202024"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F4F5"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7F1D1D"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#991B1B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C"/>
        <SolidColorBrush x:Key="EmergencyBrush" Color="#FACC15"/>
        <SolidColorBrush x:Key="EmergencyTextBrush" Color="#18181B"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="Padding" Value="9"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="Padding" Value="9"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource TopBarBrush}" BorderBrush="#2D1111" BorderThickness="0,0,0,1" Padding="18,14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="EmergencyInfoButton" Content="Emergency Info" Margin="0,0,10,0" Click="EmergencyInfoButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="DeleteVaultButton" Content="Tüm Kasayı Sil" Style="{StaticResource DangerButtonStyle}" Margin="0,0,10,0" Click="DeleteVaultButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="TrustButton" Content="Bu bilgisayara güven" Margin="0,0,10,0" Click="TrustButton_Click"/>
                    <Button Content="Çıkış" Click="LogoutButton_Click"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="USB Secure Vault" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText" Text="Hazır" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="EmergencyInfoBanner" Grid.Row="1" Background="{StaticResource EmergencyBrush}" Padding="18,12" Visibility="Collapsed">
            <DockPanel>
                <TextBlock Text="EMERGENCY INFO" Foreground="{StaticResource EmergencyTextBrush}" FontWeight="Black" Margin="0,0,14,0" DockPanel.Dock="Left"/>
                <TextBlock x:Name="EmergencyInfoText" Foreground="{StaticResource EmergencyTextBrush}" FontWeight="Black" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="18">
            <Border x:Name="SetupPanel" Style="{StaticResource PanelBorderStyle}" Padding="28" Visibility="Collapsed">
                <StackPanel Width="430" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="İlk Kurulum" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <TextBlock Text="Master şifre" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="SetupPasswordBox" Margin="0,0,0,12"/>
                    <TextBlock Text="Master şifre tekrar" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="SetupPasswordConfirmBox" Margin="0,0,0,12"/>
                    <TextBlock Text="Hatırlatma" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="SetupHintBox" Margin="0,0,0,12"/>
                    <TextBlock Text="Emergency info" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="SetupEmergencyInfoBox" Margin="0,0,0,18" MinHeight="74" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    <Button Content="Kasayı Oluştur" Style="{StaticResource PrimaryButtonStyle}" Click="SetupButton_Click"/>
                </StackPanel>
            </Border>

            <Border x:Name="MasterLoginPanel" Style="{StaticResource PanelBorderStyle}" Padding="28" Visibility="Collapsed">
                <StackPanel Width="430" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Master Giriş" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>
                    <TextBlock x:Name="MasterHintText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <TextBlock Text="Master şifre" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="MasterPasswordBox" Margin="0,0,0,18"/>
                    <Button Content="Giriş Yap" Style="{StaticResource PrimaryButtonStyle}" Click="MasterLoginButton_Click"/>
                </StackPanel>
            </Border>

            <Grid x:Name="VaultPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}" Padding="14" Margin="0,0,14,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                            <Button Content="Yeni Alan Oluştur" Style="{StaticResource PrimaryButtonStyle}" Click="CreateUserButton_Click"/>
                            <Button x:Name="DeleteUserButton" Content="Alanı Sil" Style="{StaticResource DangerButtonStyle}" Margin="0,8,0,0" Click="DeleteUserButton_Click" IsEnabled="False"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Alanlar" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ListBox x:Name="UsersList" DisplayMemberPath="Name" SelectionChanged="UsersList_SelectionChanged"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" x:Name="AddFileButton" Content="Dosya Ekle" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Click="AddFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="AddFolderButton" Content="Klasör Ekle" Margin="8,0,0,0" Click="AddFolderButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="RestoreFileButton" Content="Eski Yerine Çıkar" Margin="8,0,0,0" Click="RestoreFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="DeleteFileButton" Content="Sil" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0" Click="DeleteFileButton_Click" IsEnabled="False"/>
                            <Button DockPanel.Dock="Right" x:Name="LockUserButton" Content="Alanı Kilitle" Margin="8,0,0,0" Click="LockUserButton_Click" IsEnabled="False"/>
                            <StackPanel>
                                <TextBlock x:Name="SelectedUserTitle" Text="Alan seçin" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedUserSubtitle" Text="Dosyalar yalnızca alan şifresi girilince görünür." Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DockPanel>

                        <ListView Grid.Row="1" x:Name="FilesList" MouseDoubleClick="FilesList_MouseDoubleClick" SelectionChanged="FilesList_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Dosya" DisplayMemberBinding="{Binding Name}" Width="390"/>
                                    <GridViewColumn Header="Boyut" DisplayMemberBinding="{Binding SizeText}" Width="120"/>
                                    <GridViewColumn Header="Eklenme" DisplayMemberBinding="{Binding AddedText}" Width="180"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
